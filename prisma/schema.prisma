generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                   String              @id @default(uuid())
  name                 String
  email                String              @unique
  walletBalance        Decimal             @default(0) @db.Decimal(10, 2)
  subscriptionPlanId   String?
  subscriptionPlan     SubscriptionPlan?   @relation(fields: [subscriptionPlanId], references: [id])
  subscriptionStatus   String?
  senderIdSms          String?
  paystackCustomerCode String?
  createdAt            DateTime            @default(now())
  users                User[]
  contacts             Contact[]
  contactLists         ContactList[]
  campaigns            Campaign[]
  templates            Template[]
  walletTransactions   WalletTransaction[]
  fallbackRules        FallbackRule[]

  @@index([email])
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         String
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id])
  createdAt    DateTime @default(now())

  @@index([companyId])
}

model SubscriptionPlan {
  id                      String    @id @default(uuid())
  name                    String
  monthlyPriceKes         Int
  includedSmsCredits      Int
  includedEmailCredits    Int
  includedWhatsappCredits Int
  overageRateSms          Decimal   @db.Decimal(10, 4)
  overageRateEmail        Decimal   @db.Decimal(10, 4)
  overageRateWhatsapp     Decimal   @db.Decimal(10, 4)
  companies               Company[]
}

model WalletTransaction {
  id                String   @id @default(uuid())
  companyId         String
  company           Company  @relation(fields: [companyId], references: [id])
  type              String
  amountKes         Decimal  @db.Decimal(10, 2)
  channel           String?
  paystackReference String?
  status            String
  createdAt         DateTime @default(now())

  @@index([companyId])
  @@index([status])
  @@index([paystackReference])
}

model Contact {
  id           String   @id @default(uuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id])
  phone        String?
  email        String?
  whatsappId   String?
  customFields Json?
  tags         String[]
  createdAt    DateTime @default(now())

  @@index([companyId])
  @@index([phone])
  @@index([email])
}

model ContactList {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  name      String
  createdAt DateTime @default(now())

  @@index([companyId])
}

model Template {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  channel   String
  name      String
  content   String   @db.Text
  variables Json?
  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([channel])
}

model Campaign {
  id             String             @id @default(uuid())
  companyId      String
  company        Company            @relation(fields: [companyId], references: [id])
  channel        String
  name           String
  templateId     String?
  status         String
  scheduledAt    DateTime?
  fallbackRuleId String?
  createdAt      DateTime           @default(now())
  messages       Message[]
  fallbacks      CampaignFallback[]

  @@index([companyId])
  @@index([status])
}

model Message {
  id                String            @id @default(uuid())
  campaignId        String
  campaign          Campaign          @relation(fields: [campaignId], references: [id])
  contactId         String
  channel           String
  status            String
  providerMessageId String?
  costKes           Decimal           @db.Decimal(10, 4)
  errorMessage      String?
  sentAt            DateTime?
  deliveredAt       DateTime?
  createdAt         DateTime          @default(now())
  fallback          CampaignFallback?

  @@index([campaignId])
  @@index([status])
}

model ProviderWebhookLog {
  id          String    @id @default(uuid())
  source      String
  rawPayload  Json
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([source])
  @@index([createdAt])
}

// Add these models to your existing schema.prisma

model FallbackRule {
  id                String   @id @default(uuid())
  companyId         String
  company           Company  @relation(fields: [companyId], references: [id])
  name              String
  primaryChannel    String   // sms | email | whatsapp
  fallbackChannel   String   // sms | email | whatsapp
  triggerCondition  String   // undelivered | unread | bounced
  delayMinutes      Int      // Wait time before fallback
  enabled           Boolean  @default(true)
  createdAt         DateTime @default(now())

  @@index([companyId])
}

model CampaignFallback {
  id              String    @id @default(uuid())
  campaignId      String
  campaign        Campaign  @relation(fields: [campaignId], references: [id])
  messageId       String    @unique
  message         Message   @relation(fields: [messageId], references: [id])
  fallbackRuleId  String
  status          String    // pending | triggered | completed | cancelled
  triggerAt       DateTime  // When to check and trigger fallback
  triggeredAt     DateTime?
  fallbackMessageId String?
  createdAt       DateTime  @default(now())

  @@index([campaignId])
  @@index([status, triggerAt])
}

